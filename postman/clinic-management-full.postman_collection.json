  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runSuffix')) {",
          "    pm.collectionVariables.set('runSuffix', Date.now().toString());",
          "}",
          "",
          "var suffix = pm.collectionVariables.get('runSuffix');",
          "var last13 = suffix.slice(-13).padStart(13, '1');",
          "",
          "pm.collectionVariables.set('registeredUsername', 'registered.' + suffix);",
          "pm.collectionVariables.set('registeredEmail', 'registered.' + suffix + '@medicare.com');",
          "pm.collectionVariables.set('patientUsername', 'patient.' + suffix);",
          "pm.collectionVariables.set('patientEmail', 'patient.' + suffix + '@medicare.com');",
          "pm.collectionVariables.set('doctorUsername', 'doctor.' + suffix);",
          "pm.collectionVariables.set('doctorEmail', 'doctor.' + suffix + '@medicare.com');",
          "pm.collectionVariables.set('departmentName', 'Cardiology ' + suffix);",
          "pm.collectionVariables.set('policyNumber', 'POL-' + suffix);",
          "pm.collectionVariables.set('licenseNumber', 'DOC-' + suffix);",
          "pm.collectionVariables.set('patientCnp', last13);",
          "pm.collectionVariables.set('medicationName', 'Aspenter ' + suffix);"
        ]
      }
    }
  ],
